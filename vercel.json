{
  "framework": "nextjs",
  "functions": {
    "src/app/api/jurisia/chat/route.ts": { "maxDuration": 120 },
    "src/app/api/stripe/webhook/route.ts": { "maxDuration": 30 },
    "src/app/api/demarches/create/route.ts": { "maxDuration": 60 },
    "src/app/api/demarches/[id]/deposer/route.ts": { "maxDuration": 120 },
    "src/app/api/docuseal/webhook/route.ts": { "maxDuration": 30 },
    "src/app/api/cron/check-inpi/route.ts": { "maxDuration": 60 },
    "src/app/api/cron/daily-reminders/route.ts": { "maxDuration": 60 },
    "src/app/api/cron/conformity-score/route.ts": { "maxDuration": 60 },
    "src/app/api/cron/weekly-report/route.ts": { "maxDuration": 120 },
    "src/app/api/cron/monthly-reset/route.ts": { "maxDuration": 60 },
    "src/app/api/cron/weekly-contest/route.ts": { "maxDuration": 120 },
    "src/app/api/cron/email-sequences/route.ts": { "maxDuration": 120 },
    "src/app/api/cron/wrapped-monthly/route.ts": { "maxDuration": 180 }
  },
  "crons": [
    { "path": "/api/cron/check-inpi", "schedule": "0 */6 * * *" },
    { "path": "/api/cron/daily-reminders", "schedule": "0 8 * * *" },
    { "path": "/api/cron/conformity-score", "schedule": "0 */3 * * *" },
    { "path": "/api/cron/weekly-report", "schedule": "0 9 * * 1" },
    { "path": "/api/cron/monthly-reset", "schedule": "0 0 1 * *" },
    { "path": "/api/cron/weekly-contest", "schedule": "59 23 * * 0" },
    { "path": "/api/cron/email-sequences", "schedule": "0 10 * * *" },
    { "path": "/api/cron/wrapped-monthly", "schedule": "0 9 1 * *" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    }
  ]
}
