{
  "expo": {
    "name": "MOKSHA",
    "slug": "moksha",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "moksha",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#070B18"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "dev.purama.moksha",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "MOKSHA utilise la caméra pour scanner vos documents avec ScannerPerfect",
        "NSPhotoLibraryUsageDescription": "MOKSHA accède à vos photos pour importer des documents dans ProofVault",
        "NSFaceIDUsageDescription": "MOKSHA utilise Face ID pour sécuriser l'accès à votre coffre-fort ProofVault"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#070B18"
      },
      "package": "dev.purama.moksha",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "MOKSHA utilise la caméra pour scanner vos documents"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "MOKSHA accède à vos photos pour importer des documents"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "moksha-purama"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/moksha-purama"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
